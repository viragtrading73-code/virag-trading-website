---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import SEO from '../components/SEO.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import company from '../data/company.json';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title = company.site.defaultTitle, 
  description = company.site.defaultDescription,
  image = company.site.logo,
  type = 'website'
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">
    <SEO title={title} description={description} image={image} type={type} />
    <SchemaMarkup />
  </head>
  <body class="font-inter bg-[#F8F9FA] text-[#1F2937] antialiased flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>
