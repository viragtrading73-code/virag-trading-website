---
import { getCollection } from 'astro:content';
import company from '../data/company.json';

const currentPath = Astro.url.pathname;
const products = await getCollection('products');

// Group products by category for the mega menu
const categories = [...new Set(products.map(p => p.data.category))].sort();

const navItems = [
  { name: 'Home', path: '/' },
  { name: 'About Us', path: '/about/' },
  { name: 'Inquiry', path: '/inquiry/' }
];
---

<header class="bg-white text-gray-800 shadow-md sticky top-0 z-50 border-b-4 border-primary">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">
    
    <!-- Logo with exact sizing constraints -->
    <a href="/" class="flex items-center gap-3">
      <img src={company.site.logo} alt={`${company.name} Logo`} class="h-[48px] md:h-[68px] w-auto object-contain mix-blend-multiply" />
      <div class="flex flex-col hidden sm:flex">
        <span class="text-xl md:text-2xl font-montserrat font-extrabold tracking-wide text-primary leading-none">{company.name}</span>
        <span class="text-xs text-secondary font-bold tracking-wider uppercase mt-1">Industrial Packaging</span>
      </div>
    </a>
    
    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class={`font-bold hover:text-secondary transition-colors ${currentPath === '/' ? 'text-secondary' : 'text-primary'}`}>Home</a>
      <a href="/about/" class={`font-bold hover:text-secondary transition-colors ${currentPath.startsWith('/about') ? 'text-secondary' : 'text-primary'}`}>About Us</a>
      
      <!-- Products Mega Menu Trigger -->
      <div class="group relative">
        <a href="/products/" class={`font-bold hover:text-secondary transition-colors flex items-center gap-1 py-4 ${currentPath.startsWith('/products') ? 'text-secondary' : 'text-primary'}`}>
          Products
          <svg class="w-4 h-4 transform group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </a>
        
        <!-- Mega Menu Dropdown -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 w-[600px] bg-white shadow-2xl rounded-b-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pointer-events-none group-hover:pointer-events-auto">
          <div class="p-8 grid grid-cols-2 gap-8">
            {categories.map(category => (
              <div>
                <h3 class="font-montserrat font-bold text-primary mb-3 pb-2 border-b border-gray-100">{category}</h3>
                <ul class="space-y-2">
                  {products.filter(p => p.data.category === category).slice(0, 5).map(p => (
                    <li>
                      <a href={`/products/${p.id}/`} class="text-gray-600 text-sm hover:text-secondary font-medium transition-colors block py-1">
                        {p.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="bg-gray-50 p-4 rounded-b-xl text-center border-t border-gray-100">
            <a href="/products/" class="text-secondary font-bold hover:text-primary transition-colors inline-flex items-center gap-2">
              View All Products
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
      </div>
      
      <a href="/blog/" class={`font-bold hover:text-secondary transition-colors ${currentPath.startsWith('/blog') ? 'text-secondary' : 'text-primary'}`}>Blog</a>
      <a href="/inquiry/" class={`font-bold hover:text-secondary transition-colors ${currentPath.startsWith('/inquiry') ? 'text-secondary' : 'text-primary'}`}>Inquiry</a>
    </nav>

    <!-- Desktop CTA Cluster -->
    <div class="hidden lg:flex items-center gap-3">
      <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="flex flex-col text-right mr-2 group">
        <span class="text-xs text-gray-500 font-bold group-hover:text-primary transition-colors">Call Now</span>
        <span class="text-primary font-bold text-sm group-hover:text-secondary transition-colors">{company.contact.primaryPhone}</span>
      </a>
      <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white p-2.5 rounded-lg shadow-sm transition-colors" title="WhatsApp Us">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
      </a>
      <a href="/inquiry/" class="bg-secondary hover:bg-primary text-white px-5 py-2.5 rounded-lg font-bold transition-colors shadow-sm">
        Get a Quote
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <div class="lg:hidden flex items-center gap-3">
      <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="text-[#25D366] p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
      </a>
      <button id="mobile-menu-btn" class="text-primary focus:outline-none p-2">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 shadow-inner">
    <nav class="flex flex-col p-4 space-y-4">
      <a href="/" class={`font-bold ${currentPath === '/' ? 'text-secondary' : 'text-primary'}`}>Home</a>
      <a href="/products/" class={`font-bold ${currentPath.startsWith('/products') ? 'text-secondary' : 'text-primary'}`}>Products</a>
      <a href="/about/" class={`font-bold ${currentPath.startsWith('/about') ? 'text-secondary' : 'text-primary'}`}>About Us</a>
      <a href="/blog/" class={`font-bold ${currentPath.startsWith('/blog') ? 'text-secondary' : 'text-primary'}`}>Blog</a>
      <a href="/inquiry/" class={`font-bold ${currentPath.startsWith('/inquiry') ? 'text-secondary' : 'text-primary'}`}>Inquiry</a>
      <div class="pt-4 border-t border-gray-100 flex flex-col gap-3">
        <a href="/inquiry/" class="bg-secondary text-white text-center px-4 py-3 rounded-lg font-bold w-full">Request a Quote</a>
        <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="border border-primary text-primary text-center px-4 py-3 rounded-lg font-bold w-full flex justify-center items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          Call Us
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  if(btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
