---
import { getCollection } from 'astro:content';
import company from '../data/company.json';

const currentYear = new Date().getFullYear();
const products = await getCollection('products');
const categories = [...new Set(products.map(p => p.data.category))].sort();
---

<footer class="bg-gray-900 text-gray-300 pt-20 pb-8 border-t-8 border-secondary font-sans relative overflow-hidden">
  
  <!-- Abstract Industrial Background Pattern -->
  <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 32px 32px;"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Column 1: Company Profile -->
      <div class="flex flex-col">
        <a href="/" class="inline-block mb-6 bg-white p-2 rounded w-fit mix-blend-screen">
          <img src={company.site.logo} alt="Virag Trading Co. Logo" class="h-12 w-auto object-contain mix-blend-multiply" />
        </a>
        <p class="mb-6 text-sm leading-relaxed text-gray-400">
          Gujarat's most trusted B2B supplier of industrial packaging materials. We secure the supply chains of the manufacturing, textile, and export sectors with heavy-duty strapping and protective packaging solutions.
        </p>
        <div class="mt-4 flex gap-4">
          <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="bg-primary hover:bg-white hover:text-primary border border-primary text-white text-sm font-bold py-2.5 px-5 rounded transition-colors inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            Call Us
          </a>
          <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white text-sm font-bold py-2.5 px-5 rounded transition-colors inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
      
      <!-- Column 2: Product Categories -->
      <div>
        <h3 class="text-white text-lg font-montserrat font-bold mb-6 border-b border-gray-700 pb-3">Industrial Products</h3>
        <ul class="space-y-3">
          {categories.map(category => (
            <li>
              <a href="/products/" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-center gap-2 group">
                <span class="w-1.5 h-1.5 bg-gray-600 group-hover:bg-secondary rounded-full transition-colors"></span>
                {category}
              </a>
            </li>
          ))}
          <li>
            <a href="/products/" class="text-secondary hover:text-white transition-colors text-sm font-bold flex items-center gap-2 mt-4">
              View Entire Catalog
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Column 3: Quick Links & Locations -->
      <div>
        <h3 class="text-white text-lg font-montserrat font-bold mb-6 border-b border-gray-700 pb-3">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-center gap-2 group"><span class="w-1.5 h-1.5 bg-gray-600 group-hover:bg-secondary rounded-full"></span>Home</a></li>
          <li><a href="/about/" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-center gap-2 group"><span class="w-1.5 h-1.5 bg-gray-600 group-hover:bg-secondary rounded-full"></span>Corporate Profile</a></li>
          <li><a href="/locations/" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-center gap-2 group"><span class="w-1.5 h-1.5 bg-gray-600 group-hover:bg-secondary rounded-full"></span>Supply Network (Gujarat)</a></li>
          <li><a href="/inquiry/" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-center gap-2 group"><span class="w-1.5 h-1.5 bg-gray-600 group-hover:bg-secondary rounded-full"></span>Request Bulk Quote</a></li>
          <li>
            <a href={company.address.googleMapsLink} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-secondary transition-colors text-sm flex items-start gap-2 mt-4 group">
              <svg class="w-5 h-5 text-gray-500 group-hover:text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              View on Google Maps
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Contact & Hours -->
      <div>
        <h3 class="text-white text-lg font-montserrat font-bold mb-6 border-b border-gray-700 pb-3">Corporate Headquarters</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            <span class="text-gray-400 text-sm leading-relaxed">{company.address.fullAddress}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href={`mailto:${company.contact.email}`} class="text-gray-400 hover:text-white transition-colors text-sm">{company.contact.email}</a>
          </li>
        </ul>

        <h4 class="text-white text-sm font-montserrat font-bold mt-8 mb-3">Operating Hours</h4>
        <div class="bg-gray-800 rounded p-4 border border-gray-700">
          <ul class="space-y-2">
            {Object.entries(company.hours)
              .filter(([key]) => key !== 'openingHoursSpecification')
              .map(([day, hours]) => (
              <li class="flex justify-between items-center text-xs">
                <span class="text-gray-400">{day}</span>
                <span class="text-secondary font-bold">{hours as string}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 pt-6 pb-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm text-center md:text-left">
        &copy; {currentYear} <span class="text-gray-400 font-bold">{company.name}</span>. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="/about/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Corporate Policy</a>
        <a href="/products/" class="text-gray-500 hover:text-gray-300 text-sm transition-colors">Catalog</a>
      </div>
    </div>
  </div>
</footer>