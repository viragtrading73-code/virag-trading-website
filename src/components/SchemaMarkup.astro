---
import company from '../data/company.json';

interface Props {
  product?: any;
}

const { product } = Astro.props;

// Helper to ensure trailing slashes for schema URLs
let pathname = Astro.url.pathname;
if (!pathname.endsWith('/')) {
  pathname += '/';
}
const currentUrl = new URL(pathname, Astro.site).toString();
const siteUrl = new URL('/', Astro.site).toString();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": company.name,
  "url": siteUrl,
  "logo": new URL(company.site.logo, Astro.site).toString(),
  "telephone": company.contact.primaryPhone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": company.address.streetAddress,
    "addressLocality": company.address.addressLocality,
    "postalCode": company.address.postalCode,
    "addressCountry": company.address.addressCountry
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": company.contact.primaryPhone,
    "contactType": "customer service"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": company.name,
  "image": new URL(company.site.logo, Astro.site).toString(),
  "@id": siteUrl,
  "url": siteUrl,
  "telephone": company.contact.primaryPhone,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": company.address.streetAddress,
    "addressLocality": company.address.addressLocality,
    "postalCode": company.address.postalCode,
    "addressCountry": company.address.addressCountry
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": company.address.geo?.latitude || "21.1930102",
    "longitude": company.address.geo?.longitude || "72.8524614"
  },
  "areaServed": company.serviceArea,
  "priceRange": company.priceRange,
  "openingHoursSpecification": company.hours.openingHoursSpecification,
  "sameAs": [
    company.social.facebook,
    company.social.instagram,
    company.social.linkedin
  ].filter(Boolean)
};

// Breadcrumb Schema
const paths = pathname.split('/').filter(p => p);
let itemListElement = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": siteUrl
  }
];

if (paths.length > 0) {
  let accumPath = '';
  paths.forEach((path, index) => {
    accumPath += '/' + path;
    const isLast = index === paths.length - 1;
    let name = path.charAt(0).toUpperCase() + path.slice(1).replace(/-/g, ' ');
    
    // Override name for specific product
    if (isLast && product) {
      name = product.data.title;
    }

    itemListElement.push({
      "@type": "ListItem",
      "position": index + 2,
      "name": name,
      "item": new URL(accumPath + '/', Astro.site).toString()
    });
  });
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": itemListElement
};

let productSchema = null;
if (product) {
  const images = product.data.images.map((img: any) => {
    const src = typeof img === 'string' ? img : img.src;
    return new URL(src, Astro.site).toString();
  });

  productSchema = {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": product.data.title,
    "image": images,
    "description": product.data.description,
    "sku": product.id,
    "category": product.data.category || "Industrial Packaging",
    "keywords": product.data.keywords ? product.data.keywords.join(", ") : undefined,
    "material": product.data.specifications?.Material || undefined,
    "brand": {
      "@type": "Brand",
      "name": company.name
    },
    "manufacturer": {
      "@type": "Organization",
      "name": company.name
    },
    "offers": {
      "@type": "Offer",
      "url": currentUrl,
      "priceCurrency": "INR",
      "availability": "https://schema.org/InStock",
      "itemCondition": "https://schema.org/NewCondition"
    }
  };
}

const schemas = [organizationSchema, localBusinessSchema, breadcrumbSchema];
if (productSchema) schemas.push(productSchema);
---

<script type="application/ld+json" set:html={JSON.stringify(schemas)} />
