---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { title, description, images, slug } = product.data;
const mainImage = images[0] || '/images/products/placeholder.webp';
---

<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow flex flex-col h-full group">
  <a href={`/products/${product.id}/`} class="block overflow-hidden relative pt-[75%]">
    <img 
      src={mainImage} 
      alt={title} 
      loading="lazy" 
      class="absolute top-0 left-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
    />
  </a>
  <div class="p-6 flex flex-col flex-grow">
    <a href={`/products/${product.id}/`}>
      <h3 class="text-xl font-bold font-montserrat text-primary mb-2 hover:text-secondary transition-colors">{title}</h3>
    </a>
    <p class="text-gray-600 text-sm mb-6 flex-grow line-clamp-3">{description}</p>
    <div class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center">
      <a href={`/products/${product.id}/`} class="text-secondary font-semibold hover:text-accent flex items-center gap-1 transition-colors">
        View Details
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </div>
</div>
