---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import company from '../../data/company.json';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { title, description, keywords, images, features, specifications, applications, faq, whatsappMessage: customWhatsappMessage } = product.data;

const resolvedImages = images || [];
const mainImage = resolvedImages.length > 0 ? resolvedImages[0] : null;

const whatsappMessageText = customWhatsappMessage || `Hello Virag Trading Co,\n\nI am interested in ${title}.\n\nPlease share product details, availability and quotation.\n\nThank you.`;
const whatsappMessage = encodeURIComponent(whatsappMessageText);
const whatsappLink = `https://wa.me/${company.contact.whatsapp.replace('+', '')}?text=${whatsappMessage}`;
---

<MainLayout title={`${title} | ${company.name}`} description={description} image={mainImage} type="product" product={product}>
  
  <!-- Breadcrumb -->
  <div class="bg-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 text-sm text-gray-500">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/products/" class="hover:text-primary transition-colors">Products</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800 font-medium">{title}</span>
    </div>
  </div>

  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12">
        
        <!-- Product Images -->
        <div class="w-full lg:w-1/2">
          <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 mb-4 sticky top-24">
            {mainImage ? (
              <Image src={mainImage} alt={title} title={title} width={mainImage.width} height={mainImage.height} class="w-full h-auto object-cover rounded-lg shadow-sm" id="main-product-image" loading="eager" />
            ) : (
              <img src="/images/products/placeholder.webp" alt={title} title={title} class="w-full h-auto object-cover rounded-lg shadow-sm" id="main-product-image" />
            )}
            
            {resolvedImages && resolvedImages.length > 1 && (
              <div class="grid grid-cols-4 gap-4 mt-4">
                {resolvedImages.map((img: any) => (
                  <button class="border-2 border-transparent hover:border-secondary rounded-lg overflow-hidden transition-colors focus:outline-none focus:border-secondary product-thumbnail">
                    <Image src={img} alt={title} title={title} width={img.width} height={img.height} class="w-full h-24 object-cover" />
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Product Details -->
        <div class="w-full lg:w-1/2 space-y-8">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold font-montserrat text-primary mb-4">{title}</h1>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">{description}</p>
            
            <div class="flex flex-wrap gap-4 mt-8">
              <a href={`/inquiry/?product=${encodeURIComponent(title)}`} class="bg-secondary hover:bg-primary text-white font-bold py-3 px-8 rounded-lg shadow-md transition-colors flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                Request Quote
              </a>
              <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3 px-8 rounded-lg shadow-md flex items-center gap-2 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                WhatsApp
              </a>
              <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold py-3 px-8 rounded-lg transition-colors flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                Call
              </a>
            </div>
          </div>

          <!-- Product Content -->
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>

          <!-- Features -->
          {features && features.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold font-montserrat text-primary mb-4 border-b border-gray-200 pb-2">Key Features</h2>
              <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
                {features.map((feature: string) => (
                  <li class="flex items-center gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Specifications -->
          {specifications && Object.keys(specifications).length > 0 && (
            <div>
              <h2 class="text-2xl font-bold font-montserrat text-primary mb-4 border-b border-gray-200 pb-2">Specifications</h2>
              <div class="overflow-hidden rounded-lg border border-gray-200">
                <table class="min-w-full divide-y divide-gray-200">
                  <tbody class="bg-white divide-y divide-gray-200">
                    {Object.entries(specifications).map(([key, value]) => (
                      <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 bg-gray-50 w-1/3">{key}</td>
                        <td class="px-6 py-4 text-sm text-gray-700">{value as string}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- Applications -->
          {applications && applications.length > 0 && (
            <div>
              <h2 class="text-2xl font-bold font-montserrat text-primary mb-4 border-b border-gray-200 pb-2">Applications</h2>
              <div class="flex flex-wrap gap-2">
                {applications.map((app: string) => (
                  <span class="bg-gray-100 text-gray-800 text-sm font-medium px-4 py-2 rounded-full border border-gray-200">{app}</span>
                ))}
              </div>
            </div>
          )}

          <!-- FAQs -->
          {faq && faq.length > 0 && (
            <div class="pt-8">
              <h2 class="text-2xl font-bold font-montserrat text-primary mb-6 border-b border-gray-200 pb-2">Frequently Asked Questions</h2>
              <div class="space-y-6">
                {faq.map((item: any) => (
                  <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">{item.question}</h3>
                    <p class="text-gray-700">{item.answer}</p>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Universal Product CTA Block -->
  <section class="py-16 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h3 class="text-2xl md:text-3xl font-bold font-montserrat text-primary mb-4">Ready to Order {title} in Bulk?</h3>
      <p class="text-gray-600 mb-8">Contact Virag Trading Co. today for competitive wholesale pricing, custom specifications, and rapid delivery across Gujarat.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`/inquiry/?product=${encodeURIComponent(title)}`} class="bg-secondary hover:bg-accent text-primary font-bold py-3 px-8 rounded-lg transition-colors shadow-md hover:shadow-lg">
          Request a Quote
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3 px-8 rounded-lg transition-colors shadow-md hover:shadow-lg flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          WhatsApp Now
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  // Image gallery logic
  const mainImage = document.getElementById('main-product-image') as HTMLImageElement;
  const thumbnails = document.querySelectorAll('.product-thumbnail');

  if (mainImage && thumbnails) {
    thumbnails.forEach(thumb => {
      thumb.addEventListener('click', (e) => {
        const img = (e.currentTarget as HTMLElement).querySelector('img');
        if (img && mainImage) {
          mainImage.src = img.src;
          
          // Reset border on all
          thumbnails.forEach(t => t.classList.remove('border-secondary'));
          thumbnails.forEach(t => t.classList.add('border-transparent'));
          
          // Add border to active
          (e.currentTarget as HTMLElement).classList.remove('border-transparent');
          (e.currentTarget as HTMLElement).classList.add('border-secondary');
        }
      });
    });
  }
</script>
