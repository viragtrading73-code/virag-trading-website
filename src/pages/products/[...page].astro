---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import company from '../../data/company.json';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const products = await getCollection('products');
  return paginate(products, { pageSize: 20 });
}

const { page } = Astro.props;
const allProducts = await getCollection('products');
const searchableProducts = allProducts.map(p => {
  let resolvedImage = '/images/products/placeholder.webp';
  if (p.data.images && p.data.images.length > 0) {
    resolvedImage = p.data.images[0].src;
  }
  return {
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    keywords: p.data.keywords.join(' '),
    applications: p.data.applications.join(' '),
    image: resolvedImage
  };
});

const title = `Products | ${company.name} - Page ${page.currentPage}`;
---

<MainLayout title={title} description="Explore our comprehensive range of industrial packaging materials.">
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold font-montserrat text-white mb-4">Our Products</h1>
      <div class="w-16 h-1 bg-accent mx-auto"></div>
    </div>
  </section>

  <section class="py-12 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="relative">
        <input 
          type="text" 
          id="product-search" 
          placeholder="Search products by name, keywords, or applications..." 
          class="w-full pl-12 pr-4 py-4 rounded-xl border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary shadow-sm text-lg outline-none transition-colors"
        />
        <svg class="w-6 h-6 text-gray-400 absolute left-4 top-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white min-h-[500px]">
    <div class="container mx-auto px-4">
      
      <!-- Static paginated grid (hidden when searching) -->
      <div id="static-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {page.data.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
      
      <!-- Search results grid (hidden initially) -->
      <div id="search-grid" class="hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- populated by JS -->
      </div>
      <div id="no-results" class="hidden text-center py-12 text-gray-500 text-lg">
        No products found matching your search.
      </div>

      <!-- Pagination -->
      {page.lastPage > 1 && (
        <div id="pagination-controls" class="flex justify-center items-center gap-4 mt-16">
          {page.url.prev ? (
            <a href={page.url.prev} class="px-6 py-2 border border-primary text-primary hover:bg-primary hover:text-white rounded-md font-semibold transition-colors">Previous</a>
          ) : (
            <span class="px-6 py-2 border border-gray-200 text-gray-400 rounded-md font-semibold cursor-not-allowed">Previous</span>
          )}
          <span class="text-gray-600 font-medium">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next ? (
            <a href={page.url.next} class="px-6 py-2 border border-primary text-primary hover:bg-primary hover:text-white rounded-md font-semibold transition-colors">Next</a>
          ) : (
             <span class="px-6 py-2 border border-gray-200 text-gray-400 rounded-md font-semibold cursor-not-allowed">Next</span>
          )}
        </div>
      )}
    </div>
  </section>
</MainLayout>

<script define:vars={{ searchableProducts }}>
  const searchInput = document.getElementById('product-search');
  const staticGrid = document.getElementById('static-grid');
  const searchGrid = document.getElementById('search-grid');
  const noResults = document.getElementById('no-results');
  const paginationControls = document.getElementById('pagination-controls');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      
      if (!query) {
        staticGrid.classList.remove('hidden');
        if (paginationControls) paginationControls.classList.remove('hidden');
        searchGrid.classList.add('hidden');
        searchGrid.classList.remove('grid');
        noResults.classList.add('hidden');
        return;
      }

      staticGrid.classList.add('hidden');
      if (paginationControls) paginationControls.classList.add('hidden');
      
      const filtered = searchableProducts.filter(p => 
        p.title.toLowerCase().includes(query) ||
        p.description.toLowerCase().includes(query) ||
        p.keywords.toLowerCase().includes(query) ||
        p.applications.toLowerCase().includes(query)
      );

      if (filtered.length === 0) {
        searchGrid.classList.add('hidden');
        searchGrid.classList.remove('grid');
        noResults.classList.remove('hidden');
      } else {
        noResults.classList.add('hidden');
        searchGrid.classList.remove('hidden');
        searchGrid.classList.add('grid');
        
        searchGrid.innerHTML = filtered.map(p => `
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow flex flex-col h-full group">
            <a href="/products/${p.slug}/" class="block overflow-hidden relative pt-[75%]">
              <img src="${p.image}" alt="${p.title}" class="absolute top-0 left-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </a>
            <div class="p-6 flex flex-col flex-grow">
              <a href="/products/${p.slug}/">
                <h3 class="text-xl font-bold font-montserrat text-primary mb-2 hover:text-secondary transition-colors">${p.title}</h3>
              </a>
              <p class="text-gray-600 text-sm mb-6 flex-grow line-clamp-3">${p.description}</p>
              <div class="mt-auto pt-4 border-t border-gray-100 flex justify-between items-center">
                <a href="/products/${p.slug}/" class="text-secondary font-semibold hover:text-accent flex items-center gap-1 transition-colors">
                  View Details
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </div>
        `).join('');
      }
    });
  }
</script>
