---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const pageTitle = "Packaging Insights & Industry Blog";
const description = "Stay updated with the latest trends, tips, and insights in the industrial packaging and strapping industry from Virag Trading Co.";

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<MainLayout title={`${pageTitle} | Virag Trading Co.`} description={description} type="website">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
  </Fragment>

  <div class="bg-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 text-sm text-gray-500">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800 font-medium">Blog</span>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold font-montserrat text-primary mb-4">{pageTitle}</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">{description}</p>
      </div>

      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map(post => (
            <a href={`/blog/${post.data.slug}/`} class="group block bg-white rounded-xl shadow-sm hover:shadow-lg transition-shadow border border-gray-100 overflow-hidden">
              <div class="aspect-video bg-gray-100 relative overflow-hidden">
                <img 
                  src={post.data.featuredImage || '/images/products/placeholder.webp'} 
                  alt={post.data.title}
                  class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-6">
                <div class="text-sm text-gray-500 mb-2">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</div>
                <h2 class="text-xl font-bold text-gray-900 group-hover:text-primary transition-colors mb-3 line-clamp-2">{post.data.title}</h2>
                <p class="text-gray-600 line-clamp-3 mb-4">{post.data.excerpt}</p>
                <span class="text-primary font-medium flex items-center">
                  Read Article
                  <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center text-gray-500 py-16 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xl">Check back soon for new insights and articles!</p>
        </div>
      )}
    </div>
  </section>
</MainLayout>
