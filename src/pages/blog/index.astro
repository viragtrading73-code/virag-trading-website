---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import company from '../../data/company.json';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts.filter(post => !post.data.draft).sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

const title = `Industrial Packaging Blog & Insights | ${company.name}`;
const description = "Stay updated with the latest trends, guides, and insights in the industrial packaging sector, brought to you by Gujarat's leading packaging material supplier.";
---

<MainLayout title={title} description={description}>
  <!-- Header -->
  <section class="bg-primary py-20 border-b-8 border-secondary">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold font-montserrat text-white mb-6">Industry Insights & Knowledge Base</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">Expert advice, packaging trends, and comprehensive guides for B2B procurement and supply chain optimization.</p>
    </div>
  </section>

  <!-- Blog Listing -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {publishedPosts.map(post => (
          <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow flex flex-col h-full group">
            {post.data.coverImage && (
              <a href={`/blog/${post.id}/`} class="block overflow-hidden h-56 relative">
                <Image src={post.data.coverImage} alt={post.data.coverImageAlt || post.data.title} width={600} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                <div class="absolute top-4 left-4 bg-secondary text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </div>
              </a>
            )}
            <div class="p-8 flex flex-col flex-grow">
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="text-xs font-bold text-primary bg-primary/5 px-2.5 py-1 rounded border border-primary/10">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.id}/`} class="block">
                <h2 class="text-2xl font-bold font-montserrat text-gray-900 mb-3 group-hover:text-primary transition-colors line-clamp-2">{post.data.title}</h2>
              </a>
              <p class="text-gray-600 mb-6 flex-grow line-clamp-3">{post.data.description}</p>
              
              <div class="mt-auto pt-6 border-t border-gray-100 flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white font-bold text-xs">VT</div>
                  <span class="text-sm font-medium text-gray-700">{post.data.author}</span>
                </div>
                <a href={`/blog/${post.id}/`} class="text-secondary font-bold hover:text-primary transition-colors text-sm flex items-center gap-1">
                  Read More <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
      
      {publishedPosts.length === 0 && (
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-200">
          <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
          <h3 class="text-2xl font-bold text-gray-900 mb-2">Check Back Soon</h3>
          <p class="text-gray-500">Our packaging experts are busy writing new insights and guides.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white border-t border-gray-200">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold font-montserrat text-primary mb-6">Need Expert Packaging Advice Now?</h2>
      <a href="/inquiry/" class="bg-secondary hover:bg-primary text-white font-bold py-3.5 px-8 rounded-lg shadow-md transition-colors inline-block">
        Speak With a Consultant
      </a>
    </div>
  </section>
</MainLayout>
