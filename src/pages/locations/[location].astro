---
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths() {
  const locations = [
    { slug: 'surat', title: 'Surat', region: 'Gujarat' },
    { slug: 'gujarat', title: 'Gujarat', region: 'India' }
  ];

  return locations.map(loc => ({
    params: { location: loc.slug },
    props: { locationInfo: loc }
  }));
}

const { locationInfo } = Astro.props;
const { title, region } = locationInfo;

const pageTitle = `Packaging Material Supplier in ${title}, ${region}`;
const description = `Virag Trading Co. is the leading supplier of industrial packaging materials, jute products, and strapping solutions in ${title}, ${region}.`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<MainLayout title={`${pageTitle} | Virag Trading Co.`} description={description} type="website">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
  </Fragment>

  <div class="bg-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 text-sm text-gray-500">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/locations/" class="hover:text-primary transition-colors">Locations</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800 font-medium">{title}</span>
    </div>
  </div>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold font-montserrat text-primary mb-6">{pageTitle}</h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed">
        We are proud to serve the industrial and commercial sectors of <strong>{title}</strong>. Our comprehensive range of packaging materials ensures your goods are protected safely and efficiently. Contact us for bulk supplies and custom packaging solutions in {region}.
      </p>
      <div class="mt-10">
        <a href="/inquiry/" class="bg-secondary hover:bg-opacity-90 text-white font-bold py-3 px-8 rounded-lg shadow-lg transition-colors text-lg">
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</MainLayout>
