---
import MainLayout from '../../layouts/MainLayout.astro';

const pageTitle = "Our Service Locations in Gujarat";
const description = "Virag Trading Co. provides premium industrial packaging materials and strapping solutions across major industrial hubs in Gujarat including Ahmedabad, Surat, Vadodara, Rajkot, and Gandhinagar.";

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const locations = [
  { slug: 'ahmedabad', title: 'Ahmedabad', desc: 'Textiles, Pharma & Engineering Hub' },
  { slug: 'surat', title: 'Surat', desc: 'Diamonds, Textiles & Heavy Manufacturing' },
  { slug: 'vadodara', title: 'Vadodara', desc: 'Chemicals, Power & Petrochemicals' },
  { slug: 'rajkot', title: 'Rajkot', desc: 'Auto Parts & Machine Tools Hub' },
  { slug: 'gandhinagar', title: 'Gandhinagar', desc: 'IT, Electronics & State Infrastructure' }
];
---

<MainLayout title={`${pageTitle} | Virag Trading Co.`} description={description} type="website">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
  </Fragment>

  <div class="bg-gray-100 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3 text-sm text-gray-500">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-800 font-medium">Locations</span>
    </div>
  </div>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold font-montserrat text-primary mb-6">{pageTitle}</h1>
      <div class="w-24 h-1 bg-accent mx-auto mb-8"></div>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto leading-relaxed mb-16">
        As Gujarat's leading packaging material supplier, Virag Trading Co. ensures rapid, reliable delivery of industrial packaging solutions to manufacturing plants, logistics centers, and warehouses across the state. Select your industrial hub below to learn more about our localized supply capabilities.
      </p>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {locations.map(loc => (
          <a href={`/locations/${loc.slug}/`} class="group p-8 bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-xl hover:border-secondary transition-all text-center flex flex-col items-center justify-center h-full">
            <svg class="w-12 h-12 text-gray-400 group-hover:text-secondary mb-4 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <h2 class="text-2xl font-bold font-montserrat text-gray-900 group-hover:text-primary transition-colors mb-2">{loc.title}</h2>
            <p class="text-gray-600 text-sm">{loc.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <section class="py-16 bg-gray-50 border-t border-gray-200 text-center">
    <div class="container mx-auto px-4">
      <h3 class="text-2xl font-bold text-primary mb-4">Don't see your city listed?</h3>
      <p class="text-gray-600 mb-8 max-w-2xl mx-auto">We supply bulk industrial packaging materials across the entirety of Gujarat. Contact our logistics team to confirm delivery timelines to your specific GIDC or industrial park.</p>
      <a href="/inquiry/" class="bg-primary hover:bg-primary/90 text-white font-bold py-3 px-8 rounded-lg transition-colors inline-block">Contact Logistics Team</a>
    </div>
  </section>
</MainLayout>
