---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import company from '../data/company.json';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured).slice(0, 3);

// Mock Categories for Homepage
const categories = [
  { name: 'Jute Products', slug: 'jute-products', image: 'https://placehold.co/600x400/111827/C8A45D?text=Jute+Products', desc: 'Premium jute bags, sutli, and eco-friendly packaging.' },
  { name: 'Strapping Solutions', slug: 'strapping-solutions', image: 'https://placehold.co/600x400/111827/C8A45D?text=Strapping+Solutions', desc: 'High-strength PET, PP, and composite strapping rolls.' },
  { name: 'Packaging Materials', slug: 'packaging-materials', image: 'https://placehold.co/600x400/111827/C8A45D?text=Packaging+Materials', desc: 'BOPP tapes, stretch films, and bulk packaging materials.' },
  { name: 'Protective Packaging', slug: 'protective-packaging', image: 'https://placehold.co/600x400/111827/C8A45D?text=Protective+Packaging', desc: 'Bubble wrap, foam rolls, and edge protectors.' },
];
---

<MainLayout>
  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-20 lg:py-32">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-8">
        <!-- Left Content -->
        <div class="w-full lg:w-1/2">
          <div class="inline-block bg-primary text-secondary font-bold px-4 py-1.5 rounded-full text-sm mb-6 shadow-sm border border-secondary/20">
            Trusted Since 2016
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-montserrat text-primary leading-tight mb-6">
            Industrial Packaging Materials & Supply Solutions
          </h1>
          <p class="text-lg text-gray-600 mb-10 leading-relaxed max-w-xl">
            Virag Trading Co. supplies industrial packaging materials, strapping solutions, jute products, protective packaging products and packaging accessories across Gujarat.
          </p>
          
          <div class="flex flex-wrap gap-4 mb-10">
            <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3.5 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all flex items-center gap-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              WhatsApp Inquiry
            </a>
            <a href="/products/" class="bg-white border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold py-3.5 px-8 rounded-lg shadow-md hover:shadow-xl transition-all">
              View Products
            </a>
          </div>

          <div class="flex flex-wrap items-center gap-4 text-sm font-semibold text-gray-700">
            <span class="flex items-center gap-1"><svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Surat Based</span>
            <span class="text-gray-300">|</span>
            <span class="flex items-center gap-1"><svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Fast Response</span>
            <span class="text-gray-300">|</span>
            <span class="flex items-center gap-1"><svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Bulk Supply</span>
            <span class="text-gray-300">|</span>
            <span class="flex items-center gap-1"><svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Quality Products</span>
          </div>
        </div>

        <!-- Right Content: Floating Card Layout -->
        <div class="w-full lg:w-1/2 relative h-[500px] hidden md:block">
          <div class="absolute right-0 top-0 w-64 h-64 bg-accent/10 rounded-full blur-3xl"></div>
          <div class="absolute left-10 bottom-10 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
          
          <div class="absolute top-0 right-4 w-64 bg-white p-3 rounded-xl shadow-2xl transform rotate-2 hover:rotate-0 transition-transform duration-300 z-20">
            <img src={categories[0].image} alt="Jute Products" class="w-full h-40 object-cover rounded-lg mb-3" />
            <p class="font-bold text-primary text-center">Jute Products</p>
          </div>

          <div class="absolute top-24 left-4 w-56 bg-white p-3 rounded-xl shadow-2xl transform -rotate-3 hover:rotate-0 transition-transform duration-300 z-10">
            <img src={categories[1].image} alt="Strapping Solutions" class="w-full h-32 object-cover rounded-lg mb-3" />
            <p class="font-bold text-primary text-center">Strapping Solutions</p>
          </div>

          <div class="absolute bottom-4 right-12 w-60 bg-white p-3 rounded-xl shadow-2xl transform -rotate-1 hover:rotate-0 transition-transform duration-300 z-30">
            <img src={categories[2].image} alt="Packaging Materials" class="w-full h-36 object-cover rounded-lg mb-3" />
            <p class="font-bold text-primary text-center">Packaging Materials</p>
          </div>

          <div class="absolute bottom-24 left-16 w-52 bg-white p-3 rounded-xl shadow-xl transform rotate-3 hover:rotate-0 transition-transform duration-300 z-0">
            <img src={categories[3].image} alt="Protective Packaging" class="w-full h-28 object-cover rounded-lg mb-3" />
            <p class="font-bold text-primary text-center text-sm">Protective Packaging</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="py-20 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-primary mb-4">Our Core Categories</h2>
        <div class="w-24 h-1 bg-accent mx-auto mb-6"></div>
        <p class="text-gray-600 max-w-2xl mx-auto">Explore our comprehensive range of industrial packaging products designed for safety, durability, and reliability.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} class="group bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow border border-gray-100 block">
            <div class="h-48 overflow-hidden">
              <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold font-montserrat text-primary mb-2">{cat.name}</h3>
              <p class="text-sm text-gray-600 mb-4">{cat.desc}</p>
              <span class="text-secondary font-semibold group-hover:text-primary transition-colors inline-flex items-center gap-1">
                Explore <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-end mb-12 border-b border-gray-200 pb-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-primary mb-4">Featured Products</h2>
          <div class="w-16 h-1 bg-accent"></div>
        </div>
        <a href="/products/" class="hidden md:inline-flex items-center gap-2 text-primary font-bold hover:text-secondary transition-colors">
          View All Products
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProducts.map(product => (
          <ProductCard product={product} />
        ))}
      </div>
      
      <div class="text-center mt-12 md:hidden">
        <a href="/products/" class="inline-flex items-center gap-2 text-primary font-bold hover:text-secondary transition-colors">
          View All Products
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-primary text-white">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center gap-16">
        <div class="w-full md:w-1/2">
          <h2 class="text-3xl md:text-4xl font-bold font-montserrat mb-6">Why Virag Trading Co.?</h2>
          <div class="w-16 h-1 bg-secondary mb-8"></div>
          <p class="text-gray-300 mb-8 leading-relaxed">
            Since {company.established}, we have been a trusted cornerstone for industrial packaging in {company.address.addressLocality}. We prioritize robust supply chains, premium product quality, and unwavering commitment to customer timelines.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
             {[
              { title: "Premium Quality", desc: "Rigorous standards for every product." },
              { title: "Bulk Supply", desc: "Capacity to handle large industrial orders." },
              { title: "Timely Delivery", desc: "Fast and reliable logistics support." },
              { title: "Expert Support", desc: "Consultative approach to packaging." }
            ].map(feature => (
              <div class="bg-white/5 border border-white/10 rounded-lg p-5 hover:bg-white/10 transition-colors">
                <svg class="w-8 h-8 text-secondary mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h4 class="font-bold text-lg mb-1">{feature.title}</h4>
                <p class="text-sm text-gray-400">{feature.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="w-full md:w-1/2">
           <img src="https://placehold.co/800x600/ffffff/111827?text=Warehouse+%26+Logistics" alt="Warehouse and Supply Chain" class="w-full h-auto rounded-2xl shadow-2xl object-cover border-4 border-white/10" />
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Served -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-primary mb-4">Industries We Serve</h2>
      <div class="w-24 h-1 bg-accent mx-auto mb-12"></div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { name: "Textile", icon: "M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" },
          { name: "Logistics", icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" },
          { name: "Manufacturing", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
          { name: "Agriculture", icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" }
        ].map(industry => (
          <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition-shadow hover:border-secondary group cursor-default">
            <svg class="w-12 h-12 text-gray-400 mx-auto mb-4 group-hover:text-secondary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={industry.icon}></path></svg>
            <h3 class="font-bold text-gray-800 text-lg group-hover:text-primary transition-colors">{industry.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Inquiry CTA & Contact Information -->
  <section class="py-24 relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-[url('https://placehold.co/1920x800/f8f9fa/e5e7eb?text=Industrial+Pattern')] opacity-30 bg-cover bg-center"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="bg-primary rounded-3xl p-8 md:p-16 text-white shadow-2xl flex flex-col lg:flex-row items-center justify-between gap-12">
        
        <div class="lg:w-1/2">
          <h2 class="text-3xl md:text-5xl font-bold font-montserrat mb-6">Need bulk packaging supplies?</h2>
          <p class="text-gray-300 text-lg mb-8">Get in touch with our experts today. We provide competitive wholesale pricing and prompt delivery across Gujarat.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/inquiry/" class="bg-secondary hover:bg-accent text-primary font-bold py-4 px-8 rounded-lg transition-colors inline-block text-center shadow-lg hover:shadow-xl">
              Request Quotation
            </a>
            <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="bg-transparent border-2 border-white/20 hover:bg-white/10 text-white font-bold py-4 px-8 rounded-lg transition-colors inline-flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              Call Now
            </a>
          </div>
        </div>

        <div class="lg:w-1/3 bg-white/10 backdrop-blur-sm p-8 rounded-2xl border border-white/10 w-full">
           <h3 class="text-2xl font-bold font-montserrat mb-6 text-secondary">Contact Information</h3>
           <ul class="space-y-6">
             <li class="flex items-start gap-4">
               <svg class="w-6 h-6 text-accent mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
               <div>
                 <p class="font-semibold text-white">Office Address</p>
                 <p class="text-sm text-gray-300 mt-1">{company.address.fullAddress}</p>
               </div>
             </li>
             <li class="flex items-start gap-4">
               <svg class="w-6 h-6 text-accent mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
               <div>
                 <p class="font-semibold text-white">Email Us</p>
                 <a href={`mailto:${company.contact.email}`} class="text-sm text-gray-300 mt-1 hover:text-secondary block">{company.contact.email}</a>
               </div>
             </li>
           </ul>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Location Map -->
  <section class="bg-white pb-20">
    <div class="container mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden h-[400px]">
        <iframe 
          src={company.address.mapEmbedUrl} 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        
      </div>
    </div>
  </section>

</MainLayout>
