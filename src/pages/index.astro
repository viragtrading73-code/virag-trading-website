---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import company from '../data/company.json';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import juteImage from '../assets/images/products/jute-sutli-twine-roll.jpeg';
import strappingImage from '../assets/images/products/pet-strapping-roll-green.jpg';
import tapeImage from '../assets/images/products/bopp-tape-brown.jpg';
import bubbleImage from '../assets/images/products/air-bubble-roll-packaging.jpg';
import warehouseImage from '../assets/images/products/corrugated-sheet-packaging.jpg';
import backgroundPattern from '../assets/images/products/stretch-film-industrial-packaging.jpg';

const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured).slice(0, 3);

// Categories for Homepage
const categories = [
  { name: 'Jute Products', slug: 'products', image: juteImage, desc: 'Premium jute bags, sutli, and eco-friendly packaging for agriculture and textiles.' },
  { name: 'Strapping Solutions', slug: 'products', image: strappingImage, desc: 'High-strength PET, PP, and composite strapping rolls for heavy load security.' },
  { name: 'Packaging Materials', slug: 'products', image: tapeImage, desc: 'BOPP tapes, stretch films, and bulk packaging materials for logistics.' },
  { name: 'Protective Packaging', slug: 'products', image: bubbleImage, desc: 'Bubble wrap, foam rolls, and edge protectors to prevent transit damage.' },
];
---

<MainLayout 
  title="Packaging Material Supplier & Industrial Packaging Solutions | Virag Trading Co."
  description="Leading packaging material supplier in Gujarat. We provide comprehensive industrial packaging solutions including strapping, protective packaging, and jute products for B2B procurement teams."
>
  <!-- Hero Section -->
  <section class="relative bg-white overflow-hidden py-20 lg:py-32">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-8">
        <!-- Left Content -->
        <div class="w-full lg:w-1/2">
          <div class="inline-flex items-center gap-2 bg-primary/5 text-primary font-bold px-4 py-1.5 rounded-full text-sm mb-6 shadow-sm border border-primary/10">
            <span class="w-2 h-2 rounded-full bg-secondary"></span>
            Trusted Industrial Packaging Supplier
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-montserrat text-gray-900 leading-tight mb-6">
            Secure Your Supply Chain with Premium Packaging
          </h1>
          <p class="text-lg text-gray-600 mb-10 leading-relaxed max-w-xl font-medium">
            Virag Trading Co. is Gujarat's premier B2B packaging material supplier. We provide heavy-duty strapping solutions, protective materials, and bulk supply logistics tailored for modern manufacturing and export industries.
          </p>
          
          <div class="flex flex-wrap gap-4 mb-10">
            <a href="/inquiry/" class="bg-secondary hover:bg-primary text-white font-bold py-3.5 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all">
              Request a Bulk Quote
            </a>
            <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3.5 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all flex items-center gap-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              WhatsApp Us
            </a>
          </div>
        </div>
        
        <!-- Right Content: Premium Grid Image Display -->
        <div class="w-full lg:w-1/2 hidden md:grid grid-cols-2 gap-4 h-[500px] relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-primary/5 to-transparent rounded-3xl -z-10 translate-x-4 translate-y-4"></div>
          <Image src={strappingImage} alt="Industrial Strapping" width={400} height={400} class="w-full h-full object-cover rounded-2xl shadow-md col-span-1 row-span-2" />
          <Image src={warehouseImage} alt="Bulk Packaging Supply" width={400} height={200} class="w-full h-full object-cover rounded-2xl shadow-md" />
          <Image src={tapeImage} alt="BOPP Tapes" width={400} height={200} class="w-full h-full object-cover rounded-2xl shadow-md" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges Section -->
  <section class="bg-primary border-y border-gray-800 py-6">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-6 md:gap-12 lg:gap-16">
        {[
          { label: "Established Since 2016" },
          { label: "Bulk Order Specialists" },
          { label: "Rapid Quote Response" },
          { label: "Gujarat-Wide Supply Network" },
          { label: "Premium Industrial Standards" }
        ].map(badge => (
          <div class="flex items-center gap-2 text-white/90">
            <svg class="w-5 h-5 text-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
            <span class="font-bold text-sm tracking-wide uppercase">{badge.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="py-20 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-gray-900 mb-4">Our Core Packaging Categories</h2>
        <div class="w-24 h-1 bg-secondary mx-auto mb-6"></div>
        <p class="text-gray-600 max-w-2xl mx-auto">Explore our comprehensive range of industrial packaging products designed for safety, durability, and reliability across all supply chain environments.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} class="group bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-xl hover:border-secondary transition-all border border-gray-100 block flex flex-col h-full">
            <div class="h-48 overflow-hidden">
              <Image src={cat.image} alt={cat.name} width={600} height={400} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-bold font-montserrat text-gray-900 mb-2 group-hover:text-primary transition-colors">{cat.name}</h3>
              <p class="text-sm text-gray-600 mb-4 flex-grow">{cat.desc}</p>
              <span class="text-secondary font-bold group-hover:text-primary transition-colors inline-flex items-center gap-1 mt-auto">
                Explore Category <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bulk Supply Capabilities -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="absolute inset-0 bg-primary/5 pattern-dots pointer-events-none"></div>
    <div class="container mx-auto px-4 max-w-6xl relative z-10">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="w-full lg:w-1/2">
          <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-gray-900 mb-6">Unmatched Bulk Supply Logistics</h2>
          <div class="w-16 h-1 bg-secondary mb-8"></div>
          <p class="text-lg text-gray-700 leading-relaxed mb-6">
            Industrial manufacturers demand packaging material suppliers who can keep pace with massive production quotas. At Virag Trading Co., our warehousing and logistics infrastructure is built entirely around <strong>high-volume B2B fulfillment</strong>.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <div>
                <strong class="text-gray-900 block">Massive Inventory Reserves</strong>
                <span class="text-gray-600 text-sm">We maintain deep stock levels of strapping, tapes, and protective wraps to ensure your production line never stops.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <div>
                <strong class="text-gray-900 block">Custom Manufacturing</strong>
                <span class="text-gray-600 text-sm">Need a specific micron thickness for stretch film or custom branding on BOPP tapes? We handle specialized bulk requests.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              <div>
                <strong class="text-gray-900 block">Gujarat-Wide Dispatch</strong>
                <span class="text-gray-600 text-sm">Rapid delivery to major industrial estates including Sanand, Hazira, Morbi, and Dahej.</span>
              </div>
            </li>
          </ul>
          <a href="/inquiry/" class="bg-primary hover:bg-gray-800 text-white font-bold py-3.5 px-8 rounded-lg shadow-lg hover:shadow-xl transition-all">
            Discuss Your Procurement Needs
          </a>
        </div>
        <div class="w-full lg:w-1/2">
           <Image src={warehouseImage} alt="Bulk Packaging Supply Warehouse" width={800} height={600} class="w-full h-auto rounded-2xl shadow-2xl object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Industries Served -->
  <section class="py-20 bg-gray-900 text-gray-300">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-white mb-4">Industries We Serve</h2>
      <div class="w-24 h-1 bg-secondary mx-auto mb-12"></div>
      
      <p class="max-w-3xl mx-auto mb-16 text-lg">
        Our industrial packaging materials are trusted by leading businesses across multiple sectors. We provide specialized solutions tailored to the unique handling, storage, and transportation needs of diverse industries.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { name: "Textiles & Garments", desc: "Moisture-resistant wrappers and plastic tarpaulins.", icon: "M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" },
          { name: "Logistics & Ports", desc: "Corrugated sheets, container lashing, and composite straps.", icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" },
          { name: "Heavy Manufacturing", desc: "High-tension PET strapping rolls and pneumatic tools.", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
          { name: "Agriculture", desc: "Eco-friendly jute sutli and kantan for crop bundling.", icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" }
        ].map(industry => (
          <div class="bg-gray-800 border border-gray-700 rounded-xl p-8 hover:border-secondary group cursor-default text-center transition-colors">
            <svg class="w-12 h-12 text-gray-500 mx-auto mb-4 group-hover:text-secondary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={industry.icon}></path></svg>
            <h3 class="font-bold text-white text-lg group-hover:text-secondary transition-colors mb-2">{industry.name}</h3>
            <p class="text-sm text-gray-400">{industry.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- B2B FAQ Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold font-montserrat text-gray-900 mb-4">Frequently Asked Questions</h2>
        <div class="w-24 h-1 bg-secondary mx-auto mb-6"></div>
      </div>
      
      <div class="space-y-6">
        {[
          { q: "Do you supply packaging materials across all of Gujarat?", a: "Yes, our logistics network covers all major industrial hubs in Gujarat including Surat, Ahmedabad, Vadodara, Rajkot, Gandhinagar, and port cities like Mundra and Kandla." },
          { q: "What is your Minimum Order Quantity (MOQ) for bulk supplies?", a: "As an industrial supplier, we specialize in bulk fulfillment. MOQs vary depending on the product (e.g., tonnage for stretch film vs carton count for BOPP tape). Please contact our sales team for exact numbers." },
          { q: "Can you provide custom printed packaging tape?", a: "Absolutely. We supply high-quality custom-printed BOPP tapes featuring your company logo, handling instructions, and branding to improve supply chain security." },
          { q: "Do you offer technical support for strapping machines?", a: "Yes, we don't just sell tools; we provide full ecosystem support. This includes maintenance, repairs, and spare parts for the pneumatic and manual strapping tools we supply." }
        ].map(faq => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">{faq.q}</h3>
            <p class="text-gray-600">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Inquiry CTA -->
  <section class="py-24 relative overflow-hidden bg-white border-t border-gray-200">
    <div class="container mx-auto px-4 relative z-10">
      <div class="bg-primary rounded-3xl p-8 md:p-16 text-white shadow-2xl flex flex-col lg:flex-row items-center justify-between gap-12">
        
        <div class="lg:w-2/3">
          <h2 class="text-3xl md:text-5xl font-bold font-montserrat mb-6">Partner With Gujarat's Top Packaging Supplier</h2>
          <p class="text-gray-300 text-lg mb-8 max-w-2xl">Get in touch with our procurement specialists today. We provide competitive wholesale pricing, consistent quality, and prompt dispatch for your critical supply chain operations.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/inquiry/" class="bg-secondary hover:bg-white text-primary font-bold py-4 px-8 rounded-lg transition-colors inline-block text-center shadow-lg hover:shadow-xl">
              Request a Bulk Quote
            </a>
            <a href={`tel:${company.contact.primaryPhone.replace(/\s+/g, '')}`} class="bg-transparent border-2 border-white/20 hover:bg-white/10 text-white font-bold py-4 px-8 rounded-lg transition-colors inline-flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              Call {company.contact.primaryPhone}
            </a>
          </div>
        </div>

        <div class="lg:w-1/3 flex justify-center lg:justify-end">
          <a href={company.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center gap-3">
             <div class="w-20 h-20 bg-[#25D366] group-hover:bg-[#128C7E] rounded-full flex items-center justify-center shadow-xl transition-colors">
               <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
             </div>
             <span class="font-bold text-white group-hover:text-secondary transition-colors">Chat on WhatsApp</span>
          </a>
        </div>
        
      </div>
    </div>
  </section>

</MainLayout>
