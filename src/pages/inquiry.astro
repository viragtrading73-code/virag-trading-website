---
import MainLayout from '../layouts/MainLayout.astro';
import company from '../data/company.json';

const title = `Inquiry | ${company.name}`;
const description = `Send an inquiry for industrial packaging materials, strapping solutions, jute products, and protective packaging to ${company.name}.`;
---

<MainLayout title={title} description={description}>
  <!-- Page Header -->
  <section class="bg-primary py-16">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold font-montserrat text-white mb-4">Send an Inquiry</h1>
      <div class="w-16 h-1 bg-accent mx-auto"></div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-7xl mx-auto">
        <!-- Contact Info -->
        <div class="lg:col-span-5 space-y-8">
          <div class="bg-white rounded-xl shadow-lg p-8">
            <h2 class="text-2xl font-bold font-montserrat text-primary mb-6">Get In Touch</h2>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <div class="bg-gray-100 p-3 rounded-full text-secondary mt-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-1">Office Address</h4>
                  <p class="text-gray-600 leading-relaxed">{company.address.fullAddress}</p>
                </div>
              </li>
              
              <li class="flex items-start gap-4">
                <div class="bg-gray-100 p-3 rounded-full text-secondary mt-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-1">Phone & WhatsApp</h4>
                  <p class="text-gray-600">
                    <a href={`tel:${company.contact.primaryPhone.replace(/\\s+/g, '')}`} class="block hover:text-accent">{company.contact.primaryPhoneDisplay}</a>
                    <a href={`tel:${company.contact.secondaryPhone.replace(/\\s+/g, '')}`} class="block hover:text-accent">{company.contact.secondaryPhoneDisplay}</a>
                  </p>
                </div>
              </li>
              
              <li class="flex items-start gap-4">
                <div class="bg-gray-100 p-3 rounded-full text-secondary mt-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-1">Email</h4>
                  <a href={`mailto:${company.contact.email}`} class="text-gray-600 hover:text-accent">{company.contact.email}</a>
                </div>
              </li>
              
              <li class="flex items-start gap-4">
                <div class="bg-gray-100 p-3 rounded-full text-secondary mt-1">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-1">Business Hours</h4>
                  <p class="text-gray-600">{company.hours.days}<br/>{company.hours.time}</p>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-7">
          <div class="bg-white rounded-xl shadow-lg p-8 md:p-12">
            <h2 class="text-3xl font-montserrat font-bold text-primary mb-2">Request a Quotation</h2>
            <p class="text-gray-600 mb-8">Fill out the form below and we will get back to you promptly via WhatsApp.</p>
            
            <form id="inquiry-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="Your Name" />
                </div>
                <div>
                  <label for="mobile" class="block text-sm font-medium text-gray-700 mb-2">Mobile Number *</label>
                  <input type="tel" id="mobile" name="mobile" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="+91 98765 43210" />
                </div>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="company" class="block text-sm font-medium text-gray-700 mb-2">Company Name</label>
                  <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="Your Company" />
                </div>
                <div>
                  <label for="city" class="block text-sm font-medium text-gray-700 mb-2">City</label>
                  <input type="text" id="city" name="city" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="Surat" />
                </div>
              </div>

              <div>
                <label for="product" class="block text-sm font-medium text-gray-700 mb-2">Product Interested In *</label>
                <input type="text" id="product" name="product" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="E.g. BOPP Tape, Jute Bags..." />
              </div>
              
              <div>
                <label for="requirement" class="block text-sm font-medium text-gray-700 mb-2">Requirement Details *</label>
                <textarea id="requirement" name="requirement" rows="4" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-secondary focus:border-secondary outline-none transition-colors" placeholder="Please describe your specific requirements, quantity needed, etc."></textarea>
              </div>

              <button type="submit" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-4 px-8 rounded-lg transition-colors flex items-center justify-center gap-2 shadow-md hover:shadow-lg">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                Send Inquiry via WhatsApp
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const mobile = (document.getElementById('mobile') as HTMLInputElement).value.trim();
      const company = (document.getElementById('company') as HTMLInputElement).value.trim() || 'N/A';
      const city = (document.getElementById('city') as HTMLInputElement).value.trim() || 'N/A';
      const product = (document.getElementById('product') as HTMLInputElement).value.trim();
      const requirement = (document.getElementById('requirement') as HTMLTextAreaElement).value.trim();
      
      if (!name || !mobile || !product || !requirement) {
        alert("Please fill in all required fields.");
        return;
      }
      
      const message = `Hello Virag Trading Co.\nName: ${name}\nMobile: ${mobile}\nCompany: ${company}\nCity: ${city}\nProduct: ${product}\nRequirement:\n${requirement}\nPlease share quotation and details.\nThank You.`;
      
      const encodedMessage = encodeURIComponent(message);
      // Hardcoded WhatsApp number as requested: 917874947917
      const whatsappUrl = `https://wa.me/917874947917?text=${encodedMessage}`;
      
      window.open(whatsappUrl, '_blank');
    });
  }
</script>
