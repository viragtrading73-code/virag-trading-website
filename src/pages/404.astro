---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Page Not Found | Virag Trading Co.">
  <div class="min-h-[70vh] flex items-center justify-center bg-gray-50 py-20 px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-9xl font-bold font-montserrat text-gray-200 mb-4">404</h1>
      <h2 class="text-3xl font-bold text-primary mb-4">Page Not Found</h2>
      <p class="text-gray-600 mb-8 leading-relaxed">
        We can't seem to find the page you're looking for. It might have been removed, renamed, or did not exist in the first place.
      </p>
      <a href="/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-primary border border-transparent rounded-lg hover:bg-secondary">
        Return to Home
      </a>
    </div>
  </div>
</MainLayout>
